# ═══════════════════════════════════════════════════════
# Rook — Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_ID=your_chat_id

# ── Optional: Google Services ─────────────────────────
# Calendar + Gmail integration
# Follow setup guide: docs/google-setup.md
GOOGLE_CREDENTIALS_PATH=credentials.json

# ── Optional: Spotify ─────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ── Optional: TV / Chromecast ─────────────────────────
CHROMECAST_DEVICE_NAME=

# ── Optional: X (Twitter) posting ─────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── Optional: Voice ───────────────────────────────────
# Piper TTS (free, local) — auto-detected if model exists
# Download: see docs/voice-setup.md
PIPER_MODEL_PATH=tts_models/cs_CZ-jirka-medium.onnx

# ── Optional: Home Assistant ──────────────────────────
# Smart home control via HA REST API
# HASS_URL=http://192.168.1.100:8123
# HASS_TOKEN=your_long_lived_access_token

# ── Optional: Ollama (local LLM fallback) ─────────────
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull model: ollama pull qwen2.5:3b
# OLLAMA_ENABLED=1
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_TIMEOUT=15

# ── Advanced ──────────────────────────────────────────
# LLM model selection
MAIN_MODEL=claude-sonnet-4-20250514
ROUTER_MODEL=claude-haiku-4-5-20251001
# ESCALATION_MODEL=claude-opus-4-20250514

# Database path (default: ./rook.db)
# DB_PATH=rook.db

# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Timezone (for scheduler)
# TIMEZONE=Europe/Prague
